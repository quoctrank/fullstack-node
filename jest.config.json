{
  "testEnvironment": "node",
  "rootDir": ".",
  "testMatch": ["<rootDir>/tests/**/*.test.ts"],
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": {
          "rootDir": ".",
          "outDir": "./dist-test"
        }
      }
    ]
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "coverageDirectory": "coverage",
  "collectCoverageFrom": ["src/**/*.ts", "!src/server.ts"]
}
