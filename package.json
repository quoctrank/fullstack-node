{
  "name": "scheduled-task-app",
  "version": "1.0.0",
  "description": "Node.js Scheduled Task Application",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path');const dst='dist/database/migrations';fs.mkdirSync(dst,{recursive:true});fs.readdirSync('src/database/migrations').filter(f=>f.endsWith('.sql')).forEach(f=>fs.copyFileSync(p.join('src/database/migrations',f),p.join(dst,f)))\"",
    "start": "node --experimental-sqlite dist/server.js",
    "dev": "cross-env NODE_OPTIONS=--experimental-sqlite ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "cross-env NODE_OPTIONS=--experimental-sqlite jest --runInBand --forceExit",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-sqlite jest --testPathPattern=tests/unit --runInBand --forceExit",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-sqlite jest --testPathPattern=tests/integration --runInBand --forceExit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
